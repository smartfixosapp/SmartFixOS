{
  "name": "FnTriggerRule",
  "type": "object",
  "description": "Function trigger rule: run a Deno function on a schedule or when an entity event occurs",
  "properties": {
    "id": { "type": "string", "description": "Unique id" },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" },
    "created_by_id": { "type": "string" },
    "created_by": { "type": "string" },
    "automation_type": { "type": "string", "enum": ["scheduled", "entity"], "description": "scheduled = run on schedule; entity = run on entity create/update/delete" },
    "name": { "type": "string", "description": "Display name" },
    "description": { "type": "string" },
    "function_name": { "type": "string", "description": "Name of the Deno function to invoke" },
    "function_args": { "type": "object", "description": "Optional fixed args (for scheduled)" },
    "is_active": { "type": "boolean", "default": true },
    "is_archived": { "type": "boolean", "default": false },
    "last_run_at": { "type": "string", "format": "date-time" },
    "last_run_status": { "type": "string", "enum": ["success", "failure", null] },
    "total_runs": { "type": "integer", "default": 0 },
    "successful_runs": { "type": "integer", "default": 0 },
    "failed_runs": { "type": "integer", "default": 0 },
    "consecutive_failures": { "type": "integer", "default": 0 },
    "schedule_mode": { "type": "string", "enum": ["recurring", "one_time", null] },
    "one_time_date": { "type": "string", "format": "date-time" },
    "schedule_type": { "type": "string", "enum": ["simple", "cron", null] },
    "repeat_interval": { "type": "integer" },
    "repeat_unit": { "type": "string", "enum": ["minutes", "hours", "days", "weeks", null] },
    "start_time": { "type": "string", "pattern": "^([0-1]?[0-9]|2[0-3]):[0-5][0-9]$" },
    "repeat_on_days": { "type": "array", "items": { "type": "integer" } },
    "repeat_on_day_of_month": { "type": "integer" },
    "cron_expression": { "type": "string" },
    "ends_type": { "type": "string", "enum": ["never", "on_date", "after_count", null] },
    "ends_on_date": { "type": "string", "format": "date-time" },
    "ends_after_count": { "type": "integer" },
    "entity_name": { "type": "string", "description": "For entity type: entity name (e.g. Order)" },
    "event_types": { "type": "array", "items": { "type": "string", "enum": ["create", "update", "delete"] } }
  }
}
