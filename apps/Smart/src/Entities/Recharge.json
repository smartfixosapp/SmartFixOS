{
  "name": "Recharge",
  "type": "object",
  "properties": {
    "recharge_number": {
      "type": "string",
      "description": "N\u00famero \u00fanico de recarga (RCG-01, RCG-02, etc.)"
    },
    "phone_number": {
      "type": "string",
      "description": "N\u00famero a recargar"
    },
    "carrier": {
      "type": "string",
      "description": "Compa\u00f1\u00eda (Claro, AT&T, etc.)"
    },
    "carrier_custom": {
      "type": "string",
      "description": "Nombre personalizado si carrier = 'Otra'"
    },
    "amount": {
      "type": "number",
      "description": "Monto de la recarga"
    },
    "commission": {
      "type": "number",
      "description": "Comisi\u00f3n ganada"
    },
    "customer_name": {
      "type": "string",
      "description": "Nombre del cliente (opcional)"
    },
    "payment_method": {
      "type": "string",
      "enum": [
        "cash",
        "card",
        "ath_movil",
        "transfer"
      ],
      "description": "M\u00e9todo de pago"
    },
    "status": {
      "type": "string",
      "enum": [
        "completed",
        "failed",
        "refunded"
      ],
      "default": "completed",
      "description": "Estado de la recarga"
    },
    "confirmation_code": {
      "type": "string",
      "description": "C\u00f3digo de confirmaci\u00f3n"
    },
    "sale_id": {
      "type": "string",
      "description": "ID de la venta asociada"
    },
    "sale_number": {
      "type": "string",
      "description": "N\u00famero de venta asociado"
    },
    "employee_id": {
      "type": "string",
      "description": "ID del empleado que proces\u00f3"
    },
    "employee_name": {
      "type": "string",
      "description": "Nombre del empleado"
    },
    "notes": {
      "type": "string",
      "description": "Notas adicionales"
    },
    "refunded_at": {
      "type": "string",
      "format": "date-time",
      "description": "Fecha de reembolso"
    },
    "refund_reason": {
      "type": "string",
      "description": "Raz\u00f3n del reembolso"
    }
  },
  "required": [
    "phone_number",
    "carrier",
    "amount"
  ]
}
