{
  "name": "Tenant",
  "type": "object",
  "description": "Tienda/Negocio SaaS - Multi-tenant para SmartFixOS",
  "properties": {
    "name": {
      "type": "string",
      "minLength": 2,
      "description": "Nombre de la tienda/negocio"
    },
    "slug": {
      "type": "string",
      "description": "URL-friendly identifier (autogenerado)"
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "Email principal de la tienda (login)"
    },
    "password_hash": {
      "type": "string",
      "description": "Hash encriptado de la contrase\u00f1a (no exposer)"
    },
    "country": {
      "type": "string",
      "description": "Pa\u00eds de la tienda"
    },
    "currency": {
      "type": "string",
      "enum": [
        "USD",
        "EUR",
        "MXN",
        "COP",
        "ARS",
        "BRL"
      ],
      "default": "USD",
      "description": "Moneda de la tienda"
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "active",
        "suspended",
        "cancelled"
      ],
      "default": "pending",
      "description": "Estado de la tienda"
    },
    "plan": {
      "type": "string",
      "enum": [
        "smartfixos",
        "pro",
        "enterprise"
      ],
      "default": "smartfixos",
      "description": "Plan de suscripci\u00f3n"
    },
    "monthly_cost": {
      "type": "number",
      "default": 49,
      "description": "Costo mensual en USD"
    },
    "subscription_status": {
      "type": "string",
      "enum": [
        "active",
        "past_due",
        "cancelled",
        "paused"
      ],
      "default": "active",
      "description": "Estado de la suscripci\u00f3n"
    },
    "payment_method": {
      "type": "string",
      "enum": [
        "stripe",
        "paypal",
        "manual",
        "transfer"
      ],
      "default": "stripe",
      "description": "M\u00e9todo de pago"
    },
    "stripe_customer_id": {
      "type": "string",
      "description": "ID del cliente en Stripe"
    },
    "stripe_subscription_id": {
      "type": "string",
      "description": "ID de suscripci\u00f3n en Stripe"
    },
    "next_billing_date": {
      "type": "string",
      "format": "date",
      "description": "Pr\u00f3xima fecha de cobro"
    },
    "last_payment_date": {
      "type": "string",
      "format": "date-time",
      "description": "\u00daltimo pago realizado"
    },
    "last_payment_amount": {
      "type": "number",
      "description": "Monto del \u00faltimo pago"
    },
    "failed_payment_attempts": {
      "type": "number",
      "default": 0,
      "description": "Intentos fallidos consecutivos"
    },
    "trial_period_days": {
      "type": "number",
      "default": 0,
      "description": "D\u00edas de per\u00edodo de prueba"
    },
    "trial_end_date": {
      "type": "string",
      "format": "date",
      "description": "Fin del per\u00edodo de prueba"
    },
    "admin_name": {
      "type": "string",
      "description": "Nombre del administrador/contacto"
    },
    "admin_phone": {
      "type": "string",
      "description": "Tel\u00e9fono del administrador"
    },
    "logo_url": {
      "type": "string",
      "description": "URL del logo de la tienda"
    },
    "address": {
      "type": "string",
      "description": "Direcci\u00f3n f\u00edsica"
    },
    "timezone": {
      "type": "string",
      "default": "America/Puerto_Rico",
      "description": "Zona horaria de la tienda"
    },
    "settings": {
      "type": "object",
      "description": "Configuraciones personalizadas",
      "additionalProperties": true
    },
    "metadata": {
      "type": "object",
      "description": "Datos adicionales",
      "additionalProperties": true
    },
    "created_date": {
      "type": "string",
      "format": "date-time",
      "description": "Fecha de creaci\u00f3n"
    },
    "activated_date": {
      "type": "string",
      "format": "date-time",
      "description": "Fecha de activaci\u00f3n"
    },
    "last_login": {
      "type": "string",
      "format": "date-time",
      "description": "\u00daltimo acceso"
    }
  },
  "required": [
    "name",
    "email",
    "country",
    "password_hash"
  ]
}
