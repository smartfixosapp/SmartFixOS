{
  "name": "FixedExpense",
  "type": "object",
  "description": "Gastos operacionales recurrentes del negocio",
  "properties": {
    "name": {
      "type": "string",
      "description": "Nombre del gasto"
    },
    "category": {
      "type": "string",
      "enum": [
        "rent",
        "utilities",
        "payroll",
        "inventory",
        "marketing",
        "insurance",
        "maintenance",
        "savings",
        "taxes",
        "internet",
        "phone",
        "other"
      ],
      "default": "other",
      "description": "Categoría del gasto"
    },
    "amount": {
      "type": "number",
      "minimum": 0,
      "default": 0,
      "description": "Monto fijo en dólares"
    },
    "due_day": {
      "type": "number",
      "minimum": 1,
      "maximum": 31,
      "description": "Día de inicio de la ventana de pago (ej: 1 = desde el día 1)"
    },
    "due_day_end": {
      "type": "number",
      "minimum": 1,
      "maximum": 31,
      "description": "Día de fin de la ventana de pago (ej: 5 = hasta el día 5)"
    },
    "working_days_per_month": {
      "type": "number",
      "minimum": 1,
      "maximum": 31,
      "default": 26,
      "description": "Días laborables por mes (para calcular meta diaria)"
    },
    "percentage": {
      "type": "number",
      "minimum": 0,
      "maximum": 100,
      "description": "Porcentaje de ganancia (legacy, deprecated)"
    },
    "frequency": {
      "type": "string",
      "enum": [
        "daily",
        "weekly",
        "biweekly",
        "monthly",
        "quarterly",
        "yearly"
      ],
      "default": "monthly",
      "description": "Frecuencia de pago (legacy)"
    },
    "priority": {
      "type": "number",
      "minimum": 1,
      "maximum": 10,
      "default": 5,
      "description": "Prioridad del gasto (1 = más importante)"
    },
    "icon": {
      "type": "string",
      "description": "Emoji o ícono del gasto"
    },
    "notes": {
      "type": "string",
      "description": "Notas adicionales"
    },
    "active": {
      "type": "boolean",
      "default": true,
      "description": "Si el gasto está activo"
    }
  },
  "required": [
    "name"
  ]
}
