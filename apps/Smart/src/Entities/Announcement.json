{
  "name": "Announcement",
  "type": "object",
  "description": "Anuncios y notas enviadas al equipo",
  "properties": {
    "title": {
      "type": "string",
      "description": "T\u00edtulo del anuncio"
    },
    "message": {
      "type": "string",
      "description": "Contenido del mensaje"
    },
    "sent_to": {
      "type": "string",
      "enum": [
        "all",
        "specific"
      ],
      "description": "Audiencia del mensaje"
    },
    "recipients": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "user_id": {
            "type": "string"
          },
          "user_name": {
            "type": "string"
          },
          "read": {
            "type": "boolean",
            "default": false
          },
          "read_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "description": "Lista de destinatarios si es espec\u00edfico"
    },
    "sent_by": {
      "type": "string",
      "description": "ID del usuario que envi\u00f3"
    },
    "sent_by_name": {
      "type": "string",
      "description": "Nombre del usuario que envi\u00f3"
    },
    "sent_at": {
      "type": "string",
      "format": "date-time",
      "description": "Fecha y hora de env\u00edo"
    },
    "type": {
      "type": "string",
      "enum": [
        "note",
        "offer",
        "alert",
        "announcement"
      ],
      "default": "note",
      "description": "Tipo de anuncio"
    },
    "priority": {
      "type": "string",
      "enum": [
        "low",
        "normal",
        "high"
      ],
      "default": "normal"
    },
    "expires_at": {
      "type": "string",
      "format": "date-time",
      "description": "Fecha de expiraci\u00f3n (para ofertas)"
    },
    "active": {
      "type": "boolean",
      "default": true,
      "description": "Si el anuncio est\u00e1 activo"
    }
  },
  "required": [
    "message",
    "sent_by",
    "sent_by_name"
  ]
}
