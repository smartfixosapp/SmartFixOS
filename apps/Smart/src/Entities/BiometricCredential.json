{
  "name": "BiometricCredential",
  "type": "object",
  "description": "Credenciales biom\u00e9tricas por dispositivo para login r\u00e1pido",
  "properties": {
    "user_id": {
      "type": "string",
      "description": "ID del usuario asociado"
    },
    "user_name": {
      "type": "string",
      "description": "Nombre del usuario (cache)"
    },
    "device_id": {
      "type": "string",
      "description": "Identificador \u00fanico del dispositivo"
    },
    "device_fingerprint": {
      "type": "string",
      "description": "Huella digital del dispositivo (hash)"
    },
    "credential_id": {
      "type": "string",
      "description": "ID de la credencial biom\u00e9trica (WebAuthn)"
    },
    "public_key": {
      "type": "string",
      "description": "Clave p\u00fablica de la credencial"
    },
    "device_info": {
      "type": "object",
      "description": "Informaci\u00f3n del dispositivo",
      "properties": {
        "platform": {
          "type": "string"
        },
        "browser": {
          "type": "string"
        },
        "os": {
          "type": "string"
        }
      }
    },
    "last_used": {
      "type": "string",
      "format": "date-time",
      "description": "\u00daltima vez que se us\u00f3 esta credencial"
    },
    "active": {
      "type": "boolean",
      "default": true,
      "description": "Si la credencial est\u00e1 activa"
    }
  },
  "required": [
    "user_id",
    "device_id",
    "credential_id",
    "public_key"
  ]
}
