# Staging environment — Variables para el ambiente de pruebas
# ⚠ ESTE ARCHIVO ES SOLO REFERENCIA — las variables reales se configuran en:
#   → Vercel Dashboard > Project > Settings > Environment Variables > Preview
#
# Workflow:
#   feature/xxx  →  develop (staging)  →  main (producción)
#   Cada push a `develop` despliega en: https://smartfixos-git-develop-smartfixosapp.vercel.app

# ── Identificador de ambiente ──────────────────────────────────────────────
VITE_APP_ENV=staging

# ── URLs de staging ────────────────────────────────────────────────────────
VITE_APP_URL=https://smartfixos-git-develop-smartfixosapp.vercel.app
VITE_FUNCTION_URL=https://smartfixos-api.onrender.com
VITE_API_URL=https://smartfixos-api.onrender.com

