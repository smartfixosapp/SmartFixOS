# NOTA: Staging comparte la misma base de datos que producción.
#       Para aislamiento total, crear un proyecto Supabase separado.
VITE_SUPABASE_URL=https://idntuvtabecwubzswpwi.supabase.co
VITE_SUPABASE_ANON_KEY=<anon_key>

