# ================================================================
# SmartFixOS — Production Environment Variables
# Copy this to .env and fill in the values.
# VITE_ vars go to Vercel → Environment Variables (build-time)
# Non-VITE_ vars go to Render → Environment Variables (runtime)
# ================================================================

# ── Supabase (both Vercel & Render need these) ─────────────────
VITE_SUPABASE_URL=https://idntuvtabecwubzswpwi.supabase.co
VITE_SUPABASE_ANON_KEY=<from Supabase dashboard → API → anon key>
SUPABASE_SERVICE_ROLE_KEY=<from Supabase dashboard → API → service_role key>

# ── Frontend → Vercel ──────────────────────────────────────────
VITE_FUNCTION_URL=https://smartfixos-api.onrender.com   # Render URL
VITE_API_URL=https://smartfixos-api.onrender.com
VITE_APP_URL=https://your-app.vercel.app
VITE_APP_NAME=SmartFixOS
VITE_DB_SCHEMA=public

# ── Deno Server → Render ───────────────────────────────────────
FUNCTIONS_PORT=8686          # Render overrides with PORT env var automatically
DB_SCHEMA=public
DB_BACKEND=supabase_cloud
FN_TRIGGER_CRON_INTERVAL=120 # seconds between cron runs
RUN_MIGRATIONS=false

# ── Email (Render only) ────────────────────────────────────────
RESEND_API_KEY=<from resend.com dashboard>
FROM_EMAIL=noreply@smartfixos.com
FROM_NAME=SmartFixOS

# ── Security (Render only — Render can auto-generate) ──────────
CRON_SECRET=<random string, protects /runScheduledFnTriggers>

# ── Optional AI (Render only) ─────────────────────────────────
OPENAI_API_KEY=<your openai key if using AI features>
