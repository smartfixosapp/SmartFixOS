{
  "buildCommand": "pnpm -C apps/Smart build",
  "outputDirectory": "apps/Smart/dist",
  "installCommand": "pnpm install --no-frozen-lockfile",
  "framework": null,
  "redirects": [
    { "source": "/terms", "destination": "/legal/terms", "permanent": false },
    { "source": "/privacy", "destination": "/privacidad.html", "permanent": false }
  ],
  "rewrites": [
    { "source": "/((?!assets/|icons/|images/|\\.well-known/|registerSW\\.js|manifest\\.json|favicon\\.ico).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(index\\.html|registerSW\\.js|manifest\\.json)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/\\.well-known/apple-app-site-association",
      "headers": [
        { "key": "Content-Type", "value": "application/json" },
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ]
}
